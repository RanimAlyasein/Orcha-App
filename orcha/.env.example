# ─── Orcha Backend — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit a real .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Database
# Local dev (SQLite):  DATABASE_URL="file:./dev.db"
# Docker / Production: DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_URL=

# Server
PORT=3010
NODE_ENV=development

# Security — use a long random string in production (never the default)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Email (optional — used for password reset and invitations)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@orcha.app
