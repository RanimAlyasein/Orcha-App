# ─── Orcha — Docker Compose environment overrides ─────────────────────────────
# Copy to .env and set real values before running docker compose up.
# Never commit a real .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Database
POSTGRES_PASSWORD=change-me-in-production

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# App
NODE_ENV=production
PORT=8080

# CORS — set to your real domain(s) in production
CORS_ORIGINS=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# Backend URL used by the nginx proxy in the frontend container.
# docker-compose: handled automatically (http://backend:3010)
# Railway:        http://backend.railway.internal:3010
BACKEND_URL=http://backend:3010

# Email (optional — required for password reset and team invitations)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com
