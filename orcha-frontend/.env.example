# ─── Orcha Frontend — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# All Vite env vars must be prefixed with VITE_ to be exposed to the browser.
# ──────────────────────────────────────────────────────────────────────────────

# Backend API base URL (without trailing slash).
# Leave empty for local dev — the Vite dev proxy handles /api/ routing.
# Required only when deploying frontend and backend to different hosts.
# Example: VITE_API_URL=https://api.orcha.app
VITE_API_URL=
